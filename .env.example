# Local development defaults. Copy this file to `.env` and replace all
# production secrets before deploying.
NODE_ENV=development
API_PORT=4000

# Production domain used by Caddy in docker-compose.prod.yml.
# Point an A record for this domain at the VPS before starting production.
DOMAIN=mail.example.com

# Local development uses localhost. Production compose uses the private
# Docker network service name `postgres`; do not publish Postgres publicly.
POSTGRES_USER=qqueue
POSTGRES_PASSWORD=change-me
POSTGRES_DB=qqueue
DATABASE_URL=postgresql://qqueue:qqueue@localhost:5432/qqueue

# Optional production overrides for external services. Leave blank to use the
# bundled private Docker Compose Postgres and Redis services.
PROD_DATABASE_URL=
PROD_REDIS_HOST=
PROD_REDIS_PORT=

# Local development uses localhost. Production compose should use `redis`.
REDIS_HOST=localhost
REDIS_PORT=6379

# Generate production secrets with:
# openssl rand -hex 32
JWT_ACCESS_SECRET=change-me
JWT_REFRESH_SECRET=change-me
ENCRYPTION_KEY=change-me-32-byte-key

# Public base URL where open/click tracking links resolve. Dev uses the API
# directly; production should be https://<DOMAIN> (e.g. https://mail.example.com).
APP_URL=http://localhost:4000

# Public base URL of the web dashboard. Used to build user-facing links such as
# password reset links (e.g. https://qqueue.app/reset-password?token=...).
# Dev uses the local Vite server; production should be your dashboard domain.
PUBLIC_APP_URL=http://localhost:5173

# HMAC secret for signing email open/click tracking tokens (openssl rand -hex 32).
TRACKING_SECRET=change-me
# Shared secret for inbound ESP bounce/complaint webhooks. Leave blank to
# disable the webhook endpoint (POST /api/v1/webhooks/email-events).
WEBHOOK_SECRET=

# Object storage (S3-compatible) for email attachments. Local development uses
# the bundled MinIO container (docker-compose.yml) via localhost:9100.
# Production compose ignores this local S3_ENDPOINT and defaults to the private
# in-stack MinIO service. To use external production object storage, add
# PROD_S3_ENDPOINT to `.env` and point it at your S3-compatible endpoint.
# For MinIO/most self-hosted S3, keep S3_FORCE_PATH_STYLE=true. For AWS S3, set
# PROD_S3_ENDPOINT to an empty value and set S3_FORCE_PATH_STYLE=false.
S3_ENDPOINT=http://localhost:9100
S3_REGION=us-east-1
S3_BUCKET=qqueue-attachments
S3_ACCESS_KEY_ID=qqueue
S3_SECRET_ACCESS_KEY=qqueue-secret
S3_FORCE_PATH_STYLE=true
# Production MinIO root password (used by the bundled minio service).
MINIO_ROOT_PASSWORD=qqueue-secret
# Per-attachment size ceiling in bytes (default 10 MB).
ATTACHMENT_MAX_BYTES=10485760
# Auto-suppression defaults (used when an org has no SuppressionPolicy row).
# A soft (transient) bounce only suppresses once this many occur within the
# window; hard bounces and complaints always suppress immediately. The API and
# worker must agree on these values.
SOFT_BOUNCE_THRESHOLD=3
SOFT_BOUNCE_WINDOW_DAYS=30
# Default per-recipient-domain send cap (messages/minute) used when an org has no
# DomainThrottle row for the domain or a default. The API and worker must agree.
DEFAULT_DOMAIN_MAX_PER_MINUTE=60
# Worker polling cadence for active inbox accounts.
INBOX_SYNC_INTERVAL_SECONDS=120
# First sync imports only the latest N messages; later syncs use the stored UID.
INBOX_SYNC_MAX_MESSAGES=50

# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
