{
  "name": "qqueue",
  "version": "0.1.0",
  "private": true,
  "description": "Self-hosted email platform for developers and small teams.",
  "license": "AGPL-3.0-only",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:smoke:docker": "sh -c 'docker compose -p qqueue-smoke -f docker-compose.smoke.yml up -d --wait && DATABASE_URL=postgresql://qqueue:qqueue@localhost:55432/qqueue REDIS_HOST=localhost REDIS_PORT=56379 pnpm exec tsx scripts/docker-smoke.ts; status=$?; docker compose -p qqueue-smoke -f docker-compose.smoke.yml down -v; exit $status'",
    "test:coverage": "turbo test:coverage",
    "coverage:badges": "node scripts/generate-coverage-badges.mjs",
    "coverage": "pnpm test:coverage && pnpm coverage:badges",
    "cloud:boundary": "node scripts/check-cloud-boundary.mjs",
    "license:audit": "node scripts/check-dependency-licenses.mjs",
    "format": "prettier --write .",
    "db:generate": "pnpm --filter @qqueue/api prisma:generate",
    "db:migrate": "pnpm --filter @qqueue/api prisma:migrate"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.10.2",
    "@types/supertest": "^6.0.2",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "jsdom": "^25.0.1",
    "prettier": "^3.4.2",
    "prisma": "^6.1.0",
    "supertest": "^7.0.0",
    "turbo": "^2.3.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1",
    "vitest": "^2.1.8",
    "vitest-mock-extended": "^2.0.2"
  }
}
