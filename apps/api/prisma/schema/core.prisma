// QQueue core data model (AGPL-3.0-only).
//
// This file plus any other *.prisma file in this folder form a single Prisma
// schema. Proprietary QQueue Cloud (Phase 7) models live in cloud.prisma under a
// separate commercial license; see docs/CLOUD_BOUNDARY.md. Prisma requires both
// sides of a relation, so a few cloud back-reference fields appear on
// Organization below — they are relation metadata only and carry no logic.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  ADMIN
  MEMBER
}

enum InviteStatus {
  PENDING
  ACCEPTED
  REVOKED
}

enum ContactStatus {
  ACTIVE
  UNSUBSCRIBED
  BOUNCED
}

// Whether a recurring compose send is currently armed. Mirrors the pause/resume
// semantics campaigns already have; there is no SENT terminal state because a
// recurrence has no end.
enum RecurringSendStatus {
  ACTIVE
  PAUSED
}

// How a contact came to be a member of a list. Recorded on ContactListMember so
// imports and tag-driven segments are distinguishable from manual additions.
enum MembershipSource {
  MANUAL
  CSV_IMPORT
  SEGMENT
}

// Why an address is on the org-wide suppression list.
enum SuppressionReason {
  BOUNCE
  COMPLAINT
  UNSUBSCRIBE
  MANUAL
}

enum BounceType {
  // Permanent failure (5.x.x, invalid recipient): suppress immediately.
  HARD
  // Transient failure (4.x.x, mailbox full, greylist, deferred): only suppress
  // after the org's soft-bounce threshold is reached within the window.
  SOFT
  // Policy/reputation block (spam, blacklist): treated like HARD for suppression.
  BLOCK
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  PAUSED
  SENT
  CANCELLED
}

enum EmailJobStatus {
  PENDING
  QUEUED
  PROCESSING
  SENT
  FAILED
  CANCELLED
  // Recipient is on the suppression list: not sent, and not counted as a
  // failure or in delivery/bounce-rate math.
  SUPPRESSED
}

enum EmailOrigin {
  CAMPAIGN
  TRANSACTIONAL
  MANUAL
}

enum AbWinnerMetric {
  OPEN
  CLICK
}

enum AbTestStatus {
  // Test fraction sent across variants; waiting for the decision window.
  TESTING
  // Winner chosen; remainder send in progress/queued.
  DECIDED
  // Winner sent to the full remaining audience.
  SENT
}

enum EmailEventType {
  QUEUED
  SENT
  DELIVERED
  OPENED
  CLICKED
  BOUNCED
  COMPLAINED
  FAILED
}

enum InboxAccountStatus {
  ACTIVE
  DISABLED
}

model User {
  id                  String               @id @default(cuid())
  email               String               @unique
  name                String?
  passwordHash        String?
  // Instance administrator: may edit InstanceSettings (registration policy,
  // env status view). Set for the first user created on a fresh install;
  // backfilled for OWNERs of the oldest organization on existing installs.
  isInstanceAdmin     Boolean              @default(false)
  members             OrganizationMember[]
  apiKeys             ApiKey[]
  passwordResetTokens PasswordResetToken[]
  invitesSent         OrganizationInvite[] @relation("InvitesSent")
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
}

// Instance-wide runtime settings (install scope, not per-org). Sparse
// key-value rows: an absent key means "use the env/default value". Keys and
// value shapes are owned by src/lib/instance-settings.ts.
model InstanceSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Organization {
  id                String               @id @default(cuid())
  name              String
  members           OrganizationMember[]
  invites           OrganizationInvite[]
  smtpConnections   SMTPConnection[]
  contacts          Contact[]
  contactLists      ContactList[]
  suppressions      Suppression[]
  suppressionPolicy SuppressionPolicy?
  domainThrottles   DomainThrottle[]
  segments          Segment[]
  templates         Template[]
  campaigns         Campaign[]
  emailJobs         EmailJob[]
  emailDrafts       EmailDraft[]
  emailAttachments  EmailAttachment[]
  imageAssets       ImageAsset[]
  inboxAccounts     InboxAccount[]
  inboundMessages   InboundMessage[]
  inboundAttachments InboundAttachment[]
  recurringSends    RecurringSend[]
  emailEvents       EmailEvent[]
  apiKeys           ApiKey[]
  webhookEndpoints  WebhookEndpoint[]
  webhookDeliveries WebhookDelivery[]
  // Cloud (Phase 7) back-references — defined in cloud.prisma. Relation metadata
  // only; no AGPL obligation attaches to these fields.
  subscription      Subscription?
  usageCounters     UsageCounter[]
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
}

model OrganizationMember {
  id             String       @id @default(cuid())
  organizationId String
  userId         String
  role           UserRole     @default(MEMBER)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@unique([organizationId, userId])
}

// A pending invitation for someone to join an organization. The raw token is
// only ever in the emailed accept link; we persist its sha256 hash (same shape
// as PasswordResetToken). Invitations are the sanctioned exception to closed
// public registration: an org OWNER/ADMIN deliberately vouches for the invitee.
model OrganizationInvite {
  id              String       @id @default(cuid())
  organizationId  String
  email           String
  role            UserRole     @default(MEMBER)
  tokenHash       String       @unique
  status          InviteStatus @default(PENDING)
  invitedByUserId String
  expiresAt       DateTime
  acceptedAt      DateTime?
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitedBy       User         @relation("InvitesSent", fields: [invitedByUserId], references: [id], onDelete: Cascade)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([organizationId])
  @@index([email])
  @@index([expiresAt])
}

model SMTPConnection {
  id                String       @id @default(cuid())
  organizationId    String
  name              String
  host              String
  port              Int
  secure            Boolean      @default(true)
  usernameEncrypted String
  passwordEncrypted String
  fromEmail         String
  fromName          String?
  isDefault         Boolean      @default(false)
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  emailJobs         EmailJob[]
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
}

/// A composed message that re-sends on a cron schedule ("recurring" in Email
/// Studio). This is the compose-side counterpart to Campaign recurrence.
///
/// It exists as its own model rather than as fields on EmailDraft because a
/// draft is scratch space that is deleted once sent, whereas this must outlive
/// the composer, be listable, and be pausable. It is deliberately NOT a
/// Campaign: campaigns require a Template and a ContactList, while compose
/// sends address ad-hoc To/CC/BCC alongside contacts and lists.
///
/// Each firing creates an ordinary EmailJob with origin MANUAL, so recurring
/// sends run through the one delivery pipeline like everything else — the
/// scheduler is an extra entry point, not a parallel path.
///
/// Attachments are intentionally absent: EmailAttachment rows are claimed by a
/// single EmailJob at send time, so they cannot be reused across occurrences.
model RecurringSend {
  id               String              @id @default(cuid())
  organizationId   String
  createdByUserId  String?
  name             String
  subject          String
  html             String?
  text             String?
  // Ad-hoc addresses, plus contacts/lists resolved fresh at each occurrence so
  // a growing list is picked up without editing the schedule.
  to               String[]            @default([])
  cc               String[]            @default([])
  bcc              String[]            @default([])
  contactIds       String[]            @default([])
  listIds          String[]            @default([])
  replyTo          String?
  // Resolved to a concrete connection when the schedule is created; the worker
  // must not have to re-derive "the org default" at fire time.
  smtpConnectionId String
  templateId       String?
  variables        Json?
  cronExpression   String
  timezone         String              @default("UTC")
  status           RecurringSendStatus @default(ACTIVE)
  nextRunAt        DateTime?
  lastRunAt        DateTime?
  organization     Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  runs             RecurringSendRun[]
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@index([organizationId])
  @@index([status, nextRunAt])
}

/// One firing of a RecurringSend. Exists purely for idempotency: BullMQ can
/// deliver the same scheduled job more than once (retries, restarts), and the
/// unique key on (recurringSendId, occurrenceKey) means a repeat delivery finds
/// the run already recorded and skips creating a second EmailJob. Same role
/// CampaignRun plays for campaigns.
model RecurringSendRun {
  id              String        @id @default(cuid())
  recurringSendId String
  occurrenceKey   String
  emailJobId      String?
  recurringSend   RecurringSend @relation(fields: [recurringSendId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now())

  @@unique([recurringSendId, occurrenceKey])
  @@index([recurringSendId])
}

model Contact {
  id              String              @id @default(cuid())
  organizationId  String
  email           String
  firstName       String?
  lastName        String?
  status          ContactStatus       @default(ACTIVE)
  // Free-form labels for future segmentation, filtering, and import mapping.
  tags            String[]            @default([])
  metadata        Json?
  organization    Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  // List membership is an explicit join (ContactListMember) rather than an
  // implicit M2M so membership can carry metadata and be paginated for large
  // campaign sends.
  listMemberships ContactListMember[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@unique([organizationId, email])
}

model ContactList {
  id             String              @id @default(cuid())
  organizationId String
  name           String
  description    String?
  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  members        ContactListMember[]
  campaigns      Campaign[]
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([organizationId])
}

// Explicit contact-list membership. Replaces Prisma's implicit M2M join so a
// membership can record when (and later, how) a contact was added, and so large
// list sends can be cursor-paginated efficiently.
model ContactListMember {
  id            String           @id @default(cuid())
  contactId     String
  contactListId String
  addedAt       DateTime         @default(now())
  // How the contact was added to the list (manual selection, CSV import, or a
  // tag-driven segment). Existing rows default to MANUAL.
  source        MembershipSource @default(MANUAL)
  contact       Contact          @relation(fields: [contactId], references: [id], onDelete: Cascade)
  contactList   ContactList      @relation(fields: [contactListId], references: [id], onDelete: Cascade)

  @@unique([contactListId, contactId])
  @@index([contactId])
}

// Org-wide "never send to this address" registry. Deliberately separate from
// Contact.status so suppression applies to addresses that are not contacts
// (transactional recipients, CC/BCC, one-off sends). The send pipeline consults
// this before every send; Contact.status remains the per-contact display state.
model Suppression {
  id             String            @id @default(cuid())
  organizationId String
  email          String
  reason         SuppressionReason
  // Free-form note about provenance (e.g. "webhook", "import", an emailJobId).
  source         String?
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime          @default(now())

  @@unique([organizationId, email])
  @@index([organizationId])
}

// Per-organization auto-suppression policy. A row is optional; when absent the
// env-provided defaults (SOFT_BOUNCE_THRESHOLD / SOFT_BOUNCE_WINDOW_DAYS) apply.
// Lets operators tune how many soft bounces within the window suppress an
// address. Hard bounces and complaints suppress immediately regardless.
model SuppressionPolicy {
  id                   String       @id @default(cuid())
  organizationId       String       @unique
  softBounceThreshold  Int          @default(3)
  softBounceWindowDays Int          @default(30)
  organization         Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
}

// Per-organization send-rate cap per recipient domain, enforced by the send
// worker via a Redis fixed-window counter. An empty `domain` ("") is the
// org-wide default; a row with a specific domain overrides it. Absent rows fall
// back to the DEFAULT_DOMAIN_MAX_PER_MINUTE env default. `domain` is non-null so
// the (organizationId, domain) unique constraint also covers the default row
// (Postgres treats NULLs as distinct, which would allow duplicate defaults).
model DomainThrottle {
  id             String       @id @default(cuid())
  organizationId String
  domain         String       @default("")
  maxPerMinute   Int
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, domain])
  @@index([organizationId])
}

model Template {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  // Short human description shown on template cards. Optional.
  description    String?
  // Free-text grouping (e.g. "Onboarding", "Newsletter"). Optional; used for
  // filtering in the dashboard.
  category       String?
  // Free-form tags for filtering. Defaults to an empty list.
  tags           String[]     @default([])
  subject        String
  // Compiled, email-safe HTML (the artifact actually sent). When a template is
  // authored with MJML, `html` is the mjml2html output of `mjml`.
  html           String
  // MJML source, when the template was authored through the MJML render layer.
  // Null for plain-HTML templates. See docs/DECISIONS.md (template versioning is
  // intentionally deferred).
  mjml           String?
  text           String?
  // Managed variable definitions: [{ name, label, defaultValue, required }].
  // Drives the variables panel and supplies preview/test-send fallback values.
  variables      Json?
  // Saved sample data ({ varName: value }) so previews are reproducible.
  previewData    Json?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  campaigns      Campaign[]
  emailJobs      EmailJob[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
}

model Campaign {
  id              String            @id @default(cuid())
  organizationId  String
  templateId      String?
  contactListId   String?
  // A campaign targets a static contact list OR a dynamic segment (resolved at
  // send time). Exactly one is set; enforced by the API, not the schema.
  segmentId       String?
  name            String
  status          CampaignStatus    @default(DRAFT)
  scheduledAt     DateTime?
  cronExpression  String?
  timezone        String?
  lastRunAt       DateTime?
  nextRunAt       DateTime?
  // A/B subject testing. When enabled, the fan-out splits `abTestPercent` of the
  // audience evenly across `variants`, waits `abTestWindowMin`, then sends the
  // winning subject (by `abWinnerMetric`) to the remainder.
  abTestEnabled   Boolean           @default(false)
  abTestPercent   Int?
  abWinnerMetric  AbWinnerMetric?
  abTestWindowMin Int?
  abTestStatus    AbTestStatus?
  organization    Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  template        Template?         @relation(fields: [templateId], references: [id], onDelete: SetNull)
  contactList     ContactList?      @relation(fields: [contactListId], references: [id], onDelete: SetNull)
  segment         Segment?          @relation(fields: [segmentId], references: [id], onDelete: SetNull)
  variants        CampaignVariant[]
  emailJobs       EmailJob[]
  runs            CampaignRun[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
}

// A subject-line variant for a campaign's A/B test. The body comes from the
// template; only the subject varies. `isWinner` is set by the decision job.
model CampaignVariant {
  id         String   @id @default(cuid())
  campaignId String
  label      String
  subject    String
  isWinner   Boolean  @default(false)
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@index([campaignId])
}

// A saved, named audience defined by a rule tree (stored as JSON) that
// re-resolves to the current matching contacts every time it is used — unlike a
// Phase C "create list from segment" snapshot, which materializes a static list.
model Segment {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  description    String?
  rules          Json
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  campaigns      Campaign[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
}

model CampaignRun {
  id            String     @id @default(cuid())
  campaignId    String
  occurrenceKey String
  status        String     @default("SENDING")
  startedAt     DateTime   @default(now())
  completedAt   DateTime?
  campaign      Campaign   @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  emailJobs     EmailJob[]

  @@unique([campaignId, occurrenceKey])
}

model EmailJob {
  id               String            @id @default(cuid())
  organizationId   String
  smtpConnectionId String?
  templateId       String?
  campaignId       String?
  campaignRunId    String?
  toEmail          String
  cc               String[]          @default([])
  bcc              String[]          @default([])
  replyTo          String?
  subject          String
  html             String?
  text             String?
  variables        Json?
  origin           EmailOrigin       @default(TRANSACTIONAL)
  createdByUserId  String?
  // For A/B campaign sends: which CampaignVariant's subject this job used.
  variantId        String?
  status           EmailJobStatus    @default(PENDING)
  // Threading metadata (RFC 5322). `messageId` is the Message-ID assigned to the
  // sent message; `inReplyTo`/`references` let a reply thread correctly in the
  // recipient's client and let a future inbox anchor replies to outbound mail.
  // See docs/DECISIONS.md ("Threading Foundation Lives on EmailJob").
  messageId        String?
  inReplyTo        String?
  references       String[]          @default([])
  // Optional client-supplied idempotency key (from the `Idempotency-Key` header
  // on a transactional send). A retry with the same (organizationId,
  // idempotencyKey) returns the original job instead of sending again. NULL is
  // unconstrained (Postgres treats NULLs as distinct), so campaign/manual sends
  // that don't supply a key are unaffected.
  idempotencyKey   String?
  scheduledAt      DateTime?
  sentAt           DateTime?
  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  smtpConnection   SMTPConnection?   @relation(fields: [smtpConnectionId], references: [id], onDelete: SetNull)
  template         Template?         @relation(fields: [templateId], references: [id], onDelete: SetNull)
  campaign         Campaign?         @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  campaignRun      CampaignRun?      @relation(fields: [campaignRunId], references: [id], onDelete: SetNull)
  events           EmailEvent[]
  attachments      EmailAttachment[]
  inboundReplies   InboundMessage[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@unique([organizationId, idempotencyKey])
  @@index([messageId])
  @@index([organizationId, origin])
}

// Email Studio composer drafts. Org- and user-scoped, editable until sent. A
// draft is a snapshot of the in-progress composer state (recipients, body,
// template/SMTP selection); it is intentionally permissive so an unfinished
// message can always be saved. On send it produces an EmailJob (origin = MANUAL)
// through the shared pipeline and the draft is removed by the client.
model EmailDraft {
  id               String            @id @default(cuid())
  organizationId   String
  createdByUserId  String
  smtpConnectionId String?
  templateId       String?
  subject          String            @default("")
  html             String?
  text             String?
  to               String[]          @default([])
  cc               String[]          @default([])
  bcc              String[]          @default([])
  contactIds       String[]          @default([])
  listIds          String[]          @default([])
  replyTo          String?
  variables        Json?
  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  attachments      EmailAttachment[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([organizationId, createdByUserId])
}

// Email attachment metadata. The blob itself lives in S3-compatible object
// storage (see packages/storage) addressed by `storageKey`; only metadata lives
// here. An attachment is first linked to a draft while composing (emailDraftId),
// then linked to the EmailJob when the message is sent (emailJobId). Both FKs
// are SetNull so deleting a draft/job leaves the row harmlessly orphaned until
// cleaned up. See docs/DECISIONS.md ("Object Storage (S3/MinIO) for Attachments").
model EmailAttachment {
  id              String       @id @default(cuid())
  organizationId  String
  emailJobId      String?
  emailDraftId    String?
  filename        String
  contentType     String
  size            Int
  storageKey      String
  createdByUserId String?
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  emailJob        EmailJob?    @relation(fields: [emailJobId], references: [id], onDelete: SetNull)
  emailDraft      EmailDraft?  @relation(fields: [emailDraftId], references: [id], onDelete: SetNull)
  createdAt       DateTime     @default(now())

  @@index([organizationId])
  @@index([emailJobId])
  @@index([emailDraftId])
}

/// An image embedded in email HTML (editor "insert image" uploads). Unlike
/// EmailAttachment — which is private and travels inside the message — these
/// blobs are served publicly and unauthenticated, because recipients' mail
/// clients fetch them with no session. `publicId` is a random token rather than
/// the cuid primary key so the public URL can't be enumerated.
model ImageAsset {
  id              String       @id @default(cuid())
  publicId        String       @unique
  organizationId  String
  filename        String
  contentType     String
  size            Int
  storageKey      String
  createdByUserId String?
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt       DateTime     @default(now())

  @@index([organizationId])
}

model EmailEvent {
  id                String            @id @default(cuid())
  organizationId    String
  emailJobId        String
  type              EmailEventType
  metadata          Json?
  organization      Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  emailJob          EmailJob          @relation(fields: [emailJobId], references: [id], onDelete: Cascade)
  webhookDeliveries WebhookDelivery[]
  occurredAt        DateTime          @default(now())
}

// Inbox module. Accounts are read-only IMAP connection records used by the sync
// worker; credentials are encrypted like SMTP secrets.
model InboxAccount {
  id                String             @id @default(cuid())
  organizationId    String
  name              String
  email             String
  host              String
  port              Int
  secure            Boolean            @default(true)
  usernameEncrypted String
  passwordEncrypted String
  mailbox           String             @default("INBOX")
  status            InboxAccountStatus @default(ACTIVE)
  lastSyncedAt      DateTime?
  lastSeenUid       Int?
  organization      Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  inboundMessages   InboundMessage[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@unique([organizationId, email])
  @@index([organizationId])
}

// Received mail synced from IMAP. This stays separate from EmailJob: EmailJob is
// outbound identity, while inbound storage belongs to the inbox module.
// Replies are anchored to sent mail by matching In-Reply-To/References against
// EmailJob.messageId.
model InboundMessage {
  id                     String                 @id @default(cuid())
  organizationId         String
  inboxAccountId         String
  emailJobId             String?
  messageId              String
  inReplyTo              String?
  references             String[]               @default([])
  fromEmail              String
  fromName               String?
  to                     String[]               @default([])
  cc                     String[]               @default([])
  subject                String
  text                   String?
  html                   String?
  receivedAt             DateTime
  readAt                 DateTime?
  imapUid                Int?
  organization           Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  inboxAccount           InboxAccount           @relation(fields: [inboxAccountId], references: [id], onDelete: Cascade)
  emailJob               EmailJob?              @relation(fields: [emailJobId], references: [id], onDelete: SetNull)
  attachments            InboundAttachment[]
  createdAt              DateTime               @default(now())

  @@unique([inboxAccountId, messageId])
  @@index([organizationId, receivedAt])
  @@index([organizationId, readAt])
  @@index([emailJobId])
  @@index([inReplyTo])
}

/// A file attached to a received message. Deliberately a separate model from
/// EmailAttachment: that one is outbound (it travels *into* a send and its FKs
/// point at EmailJob/EmailDraft), whereas this is inbound and owned by the
/// message it arrived on — hence onDelete: Cascade rather than SetNull.
///
/// Blobs live in object storage exactly like outbound attachments; only
/// metadata is in Postgres. `contentId` retains the MIME Content-ID so a
/// `cid:` reference in the HTML body can be resolved to its part, and
/// `isInline` marks parts the sender meant to display rather than list.
model InboundAttachment {
  id               String         @id @default(cuid())
  organizationId   String
  inboundMessageId String
  filename         String
  contentType      String
  size             Int
  storageKey       String
  contentId        String?
  isInline         Boolean        @default(false)
  organization     Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  inboundMessage   InboundMessage @relation(fields: [inboundMessageId], references: [id], onDelete: Cascade)
  createdAt        DateTime       @default(now())

  @@index([organizationId])
  @@index([inboundMessageId])
}

model ApiKey {
  id             String       @id @default(cuid())
  organizationId String
  userId         String?
  name           String
  keyHash        String       @unique
  lastUsedAt     DateTime?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt      DateTime     @default(now())
  revokedAt      DateTime?
}

model WebhookEndpoint {
  id              String            @id @default(cuid())
  organizationId  String
  name            String
  url             String
  events          String[]
  secretEncrypted String
  enabled         Boolean           @default(true)
  organization    Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  deliveries      WebhookDelivery[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  deletedAt       DateTime?
}

model WebhookDelivery {
  id             String          @id @default(cuid())
  organizationId String
  endpointId     String
  emailEventId   String
  eventName      String
  payload        Json
  status         String          @default("PENDING")
  attempts       Int             @default(0)
  responseStatus Int?
  error          String?
  nextAttemptAt  DateTime?
  deliveredAt    DateTime?
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  endpoint       WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)
  emailEvent     EmailEvent      @relation(fields: [emailEventId], references: [id], onDelete: Cascade)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([endpointId])
  @@index([emailEventId])
  @@index([status, nextAttemptAt])
}
