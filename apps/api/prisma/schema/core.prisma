// QQueue core data model (AGPL-3.0-only).
//
// This file plus any other *.prisma file in this folder form a single Prisma
// schema. Proprietary QQueue Cloud (Phase 7) models live in cloud.prisma under a
// separate commercial license; see docs/CLOUD_BOUNDARY.md. Prisma requires both
// sides of a relation, so a few cloud back-reference fields appear on
// Organization below — they are relation metadata only and carry no logic.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  ADMIN
  MEMBER
}

enum ContactStatus {
  ACTIVE
  UNSUBSCRIBED
  BOUNCED
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  PAUSED
  SENT
  CANCELLED
}

enum EmailJobStatus {
  PENDING
  QUEUED
  PROCESSING
  SENT
  FAILED
  CANCELLED
}

enum EmailOrigin {
  CAMPAIGN
  TRANSACTIONAL
  MANUAL
}

enum EmailEventType {
  QUEUED
  SENT
  DELIVERED
  OPENED
  CLICKED
  BOUNCED
  COMPLAINED
  FAILED
}

model User {
  id           String               @id @default(cuid())
  email        String               @unique
  name         String?
  passwordHash String?
  members      OrganizationMember[]
  apiKeys      ApiKey[]
  passwordResetTokens PasswordResetToken[]
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Organization {
  id              String               @id @default(cuid())
  name            String
  members         OrganizationMember[]
  smtpConnections SMTPConnection[]
  contacts        Contact[]
  contactLists    ContactList[]
  templates       Template[]
  campaigns       Campaign[]
  emailJobs       EmailJob[]
  emailDrafts     EmailDraft[]
  emailAttachments EmailAttachment[]
  emailEvents     EmailEvent[]
  apiKeys         ApiKey[]
  webhookEndpoints WebhookEndpoint[]
  webhookDeliveries WebhookDelivery[]
  // Cloud (Phase 7) back-references — defined in cloud.prisma. Relation metadata
  // only; no AGPL obligation attaches to these fields.
  subscription    Subscription?
  usageCounters   UsageCounter[]
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
}

model OrganizationMember {
  id             String       @id @default(cuid())
  organizationId String
  userId         String
  role           UserRole     @default(MEMBER)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@unique([organizationId, userId])
}

model SMTPConnection {
  id                String       @id @default(cuid())
  organizationId    String
  name              String
  host              String
  port              Int
  secure            Boolean      @default(true)
  usernameEncrypted String
  passwordEncrypted String
  fromEmail         String
  fromName          String?
  isDefault         Boolean      @default(false)
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  emailJobs         EmailJob[]
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
}

model Contact {
  id             String              @id @default(cuid())
  organizationId String
  email          String
  firstName      String?
  lastName       String?
  status         ContactStatus       @default(ACTIVE)
  // Free-form labels for future segmentation, filtering, and import mapping.
  tags           String[]            @default([])
  metadata       Json?
  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  // List membership is an explicit join (ContactListMember) rather than an
  // implicit M2M so membership can carry metadata and be paginated for large
  // campaign sends.
  listMemberships ContactListMember[]
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@unique([organizationId, email])
}

model ContactList {
  id             String              @id @default(cuid())
  organizationId String
  name           String
  description    String?
  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  members        ContactListMember[]
  campaigns      Campaign[]
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([organizationId])
}

// Explicit contact-list membership. Replaces Prisma's implicit M2M join so a
// membership can record when (and later, how) a contact was added, and so large
// list sends can be cursor-paginated efficiently.
model ContactListMember {
  id            String      @id @default(cuid())
  contactId     String
  contactListId String
  addedAt       DateTime    @default(now())
  contact       Contact     @relation(fields: [contactId], references: [id], onDelete: Cascade)
  contactList   ContactList @relation(fields: [contactListId], references: [id], onDelete: Cascade)

  @@unique([contactListId, contactId])
  @@index([contactId])
}

model Template {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  subject        String
  // Compiled, email-safe HTML (the artifact actually sent). When a template is
  // authored with MJML, `html` is the mjml2html output of `mjml`.
  html           String
  // MJML source, when the template was authored through the MJML render layer.
  // Null for plain-HTML templates. See docs/DECISIONS.md (template versioning is
  // intentionally deferred).
  mjml           String?
  text           String?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  campaigns      Campaign[]
  emailJobs      EmailJob[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
}

model Campaign {
  id             String         @id @default(cuid())
  organizationId String
  templateId     String?
  contactListId  String?
  name           String
  status         CampaignStatus @default(DRAFT)
  scheduledAt    DateTime?
  cronExpression String?
  timezone       String?
  lastRunAt      DateTime?
  nextRunAt      DateTime?
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  template       Template?      @relation(fields: [templateId], references: [id], onDelete: SetNull)
  contactList    ContactList?   @relation(fields: [contactListId], references: [id], onDelete: SetNull)
  emailJobs      EmailJob[]
  runs           CampaignRun[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model CampaignRun {
  id            String     @id @default(cuid())
  campaignId    String
  occurrenceKey String
  status        String     @default("SENDING")
  startedAt     DateTime   @default(now())
  completedAt   DateTime?
  campaign      Campaign   @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  emailJobs     EmailJob[]

  @@unique([campaignId, occurrenceKey])
}

model EmailJob {
  id               String          @id @default(cuid())
  organizationId   String
  smtpConnectionId String?
  templateId       String?
  campaignId       String?
  campaignRunId    String?
  toEmail          String
  cc               String[]        @default([])
  bcc              String[]        @default([])
  replyTo          String?
  subject          String
  html             String?
  text             String?
  variables        Json?
  origin           EmailOrigin     @default(TRANSACTIONAL)
  createdByUserId  String?
  status           EmailJobStatus  @default(PENDING)
  // Threading metadata (RFC 5322). `messageId` is the Message-ID assigned to the
  // sent message; `inReplyTo`/`references` let a reply thread correctly in the
  // recipient's client and let a future inbox anchor replies to outbound mail.
  // See docs/DECISIONS.md ("Threading Foundation Lives on EmailJob").
  messageId        String?
  inReplyTo        String?
  references       String[]        @default([])
  scheduledAt      DateTime?
  sentAt           DateTime?
  organization     Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  smtpConnection   SMTPConnection? @relation(fields: [smtpConnectionId], references: [id], onDelete: SetNull)
  template         Template?       @relation(fields: [templateId], references: [id], onDelete: SetNull)
  campaign         Campaign?       @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  campaignRun      CampaignRun?    @relation(fields: [campaignRunId], references: [id], onDelete: SetNull)
  events           EmailEvent[]
  attachments      EmailAttachment[]
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([messageId])
  @@index([organizationId, origin])
}

// Email Studio composer drafts. Org- and user-scoped, editable until sent. A
// draft is a snapshot of the in-progress composer state (recipients, body,
// template/SMTP selection); it is intentionally permissive so an unfinished
// message can always be saved. On send it produces an EmailJob (origin = MANUAL)
// through the shared pipeline and the draft is removed by the client.
model EmailDraft {
  id               String       @id @default(cuid())
  organizationId   String
  createdByUserId  String
  smtpConnectionId String?
  templateId       String?
  subject          String       @default("")
  html             String?
  text             String?
  to               String[]     @default([])
  cc               String[]     @default([])
  bcc              String[]     @default([])
  contactIds       String[]     @default([])
  listIds          String[]     @default([])
  replyTo          String?
  variables        Json?
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  attachments      EmailAttachment[]
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([organizationId, createdByUserId])
}

// Email attachment metadata. The blob itself lives in S3-compatible object
// storage (see packages/storage) addressed by `storageKey`; only metadata lives
// here. An attachment is first linked to a draft while composing (emailDraftId),
// then linked to the EmailJob when the message is sent (emailJobId). Both FKs
// are SetNull so deleting a draft/job leaves the row harmlessly orphaned until
// cleaned up. See docs/DECISIONS.md ("Object Storage (S3/MinIO) for Attachments").
model EmailAttachment {
  id              String       @id @default(cuid())
  organizationId  String
  emailJobId      String?
  emailDraftId    String?
  filename        String
  contentType     String
  size            Int
  storageKey      String
  createdByUserId String?
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  emailJob        EmailJob?    @relation(fields: [emailJobId], references: [id], onDelete: SetNull)
  emailDraft      EmailDraft?  @relation(fields: [emailDraftId], references: [id], onDelete: SetNull)
  createdAt       DateTime     @default(now())

  @@index([organizationId])
  @@index([emailJobId])
  @@index([emailDraftId])
}

model EmailEvent {
  id             String         @id @default(cuid())
  organizationId String
  emailJobId     String
  type           EmailEventType
  metadata       Json?
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  emailJob       EmailJob       @relation(fields: [emailJobId], references: [id], onDelete: Cascade)
  webhookDeliveries WebhookDelivery[]
  occurredAt     DateTime       @default(now())
}

model ApiKey {
  id             String       @id @default(cuid())
  organizationId String
  userId         String?
  name           String
  keyHash        String       @unique
  lastUsedAt     DateTime?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt      DateTime     @default(now())
  revokedAt      DateTime?
}

model WebhookEndpoint {
  id              String            @id @default(cuid())
  organizationId  String
  name            String
  url             String
  events          String[]
  secretEncrypted String
  enabled         Boolean           @default(true)
  organization    Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  deliveries      WebhookDelivery[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  deletedAt       DateTime?
}

model WebhookDelivery {
  id              String           @id @default(cuid())
  organizationId  String
  endpointId      String
  emailEventId    String
  eventName       String
  payload         Json
  status          String           @default("PENDING")
  attempts        Int              @default(0)
  responseStatus  Int?
  error           String?
  nextAttemptAt   DateTime?
  deliveredAt     DateTime?
  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  endpoint        WebhookEndpoint  @relation(fields: [endpointId], references: [id], onDelete: Cascade)
  emailEvent      EmailEvent       @relation(fields: [emailEventId], references: [id], onDelete: Cascade)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([endpointId])
  @@index([emailEventId])
  @@index([status, nextAttemptAt])
}
